# =====================================================================
# AnointedCoder Platform, environment variables
# Copy this file to .env.local in apps/web and apps/api as needed.
# Never commit real values.
# =====================================================================

# ---------- Web (apps/web) ----------
# Public Clerk key, safe to ship to the browser.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Secret Clerk key, server-only.
CLERK_SECRET_KEY=sk_test_replace_me

# Clerk redirect paths.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/role-select

# Base URL for the API client. During Phase 1 this points at the mock
# route handlers inside the Next.js app. In later phases this becomes
# the deployed NestJS URL.
NEXT_PUBLIC_API_BASE_URL=/api/mock

# Public site URL, used for absolute links and metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- API (apps/api) ----------
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database, wired up in Phase 2.
# DATABASE_URL=postgresql://user:password@localhost:5432/anointedcoder
